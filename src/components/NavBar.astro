---
const currentPath = Astro.url.pathname;

import TopHeader from "./TopHeader.astro";
---
<TopHeader/>
<nav id="main-navbar" class="bg-white w-full z-10 shadow py-4">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between items-center h-16">
            <div class="flex-shrink-0">
                <a href="/">
                    <img src="/images/logo.png" alt="Estructura Metálica Ato & Peña" class="w-32 h-auto">
                </a>
            </div>
            <div class="hidden md:flex space-x-5">
                <a href="/" class={`block px-5 py-2 rounded-md transition duration-300 transform ${currentPath === '/' ? 'bg-gradient-to-l from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                    Inicio
                </a>
                <a href="/nosotros" class={`block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/nosotros' ? 'bg-gradient-to-l from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-l hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                    Nosotros
                </a>
                <a href="/productos" class={`block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/productos' ? 'bg-gradient-to-l from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-l hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                    Productos
                </a>
                <a href="/servicios" class={`block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/servicios' ? 'bg-gradient-to-l from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-l hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                    Servicios
                </a>
                <a href="/contactenos" class={`block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/contactenos' ? 'bg-gradient-to-l from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-l hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                    Contáctenos
                </a>
            </div>
            <div class="flex md:hidden items-center">
                <button id="menu-button" class="text-green-900 focus:outline-none">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
    <div id="mobile-menu" class="md:hidden hidden text-center">
        <div class="px-6 pt-2 pb-3 space-y-1 sm:px-3">
            <a href="/" class={`nav-link block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/' ? 'bg-gradient-to-r from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                Inicio
            </a>
            <a href="/nosotros" class={`nav-link block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/nosotros' ? 'bg-gradient-to-r from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                Nosotros
            </a>
            <a href="/productos" class={`nav-link block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/productos' ? 'bg-gradient-to-r from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                Productos
            </a>
            <a href="/servicios" class={`nav-link block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/servicios' ? 'bg-gradient-to-r from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                Servicios
            </a>
            <a href="/contactenos" class={`nav-link block px-3 py-2 rounded-md transition duration-300 transform ${currentPath === '/contactenos' ? 'bg-gradient-to-r from-[#70d959] to-[#4cae36] text-white shadow-md scale-105' : 'text-green-900 hover:bg-gradient-to-r hover:from-green-700 hover:to-green-900 hover:text-white hover:scale-105'}`}>
                Contáctenos
            </a>
        </div>
    </div>
</nav>

<script>
    const menuButton = document.getElementById('menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const navbar = document.getElementById('main-navbar');

    menuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
    });
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            navbar.classList.add('fixed', 'top-0', 'bg-white');
            navbar.classList.remove('shadow');
        } else {
            navbar.classList.remove('fixed', 'top-0');
            navbar.classList.add('shadow');
        }
    });
</script>