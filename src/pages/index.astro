	<section class="bg-gray-100 py-12">
		<div class="container mx-auto px-6 lg:px-12">
			<!-- Título de la galería -->
			<h2 class="text-4xl font-extrabold text-center mb-12 text-green-900">Galería <br> de Proyectos</h2>
			<!-- Contenedor del Slider -->
			<div class="relative overflow-hidden">
				<div id="gallery" class="flex transition-transform duration-500 ease-in-out">
					{images.map(image => (
						<div class="min-w-[100%] sm:min-w-[100%] md:min-w-[33.33%] lg:min-w-[20%] p-2">
							<div class="bg-green-600 rounded-lg border-4 border-transparent transition duration-300 ease-in-out shadow-lg
